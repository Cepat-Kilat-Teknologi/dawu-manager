{
  "name": "dawu-manager",
  "version": "0.1.0",
  "description": "Web management dashboard for dawos-agent BNG nodes — manage multiple PPPoE/accel-ppp instances from a single UI",
  "author": "Cepat Kilat Teknologi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cepat-Kilat-Teknologi/dawu-manager.git"
  },
  "homepage": "https://github.com/Cepat-Kilat-Teknologi/dawu-manager",
  "keywords": [
    "bng",
    "pppoe",
    "accel-ppp",
    "dawos",
    "isp",
    "noc",
    "network-management",
    "dashboard"
  ],
  "bin": {
    "dawu-manager": "./bin/cli.mjs"
  },
  "files": [
    "bin/",
    ".next/standalone/",
    ".next/static/",
    "public/",
    "prisma/migrations/",
    "prisma/schema.prisma",
    "migrate.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev --port 3789",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start --port 3789",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "happy-dom": "^20.10.6",
    "prisma": "^7.8.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
