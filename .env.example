# dawu-manager environment configuration
# Copy to .env and update values before running

# Required: random secret for JWT signing and API key encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-string

# Required: base URL of this dawu-manager instance
NEXTAUTH_URL=http://localhost:3789

# Default port (used by Next.js dev/start and Docker)
PORT=3789

# SQLite database path (auto-created on first run)
DATABASE_URL=file:./prisma/dev.db
