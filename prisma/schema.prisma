// Prisma schema for dawu-manager
// SQLite — zero-config embedded database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Auth — users and browser sessions
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         String     @default("viewer") // admin | operator | viewer
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions     Session[]
  auditLogs    AuditLog[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Infrastructure — managed dawos-agent nodes
// ---------------------------------------------------------------------------

model Node {
  id        String     @id @default(cuid())
  name      String     @unique
  url       String
  apiKey    String
  location  String?
  tags      String? // JSON array: ["production","jakarta"]
  status    String     @default("unknown") // online | offline | degraded | unknown
  lastSeen  DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auditLogs AuditLog[]
}

// ---------------------------------------------------------------------------
// Observability — central audit trail
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  nodeId    String?
  action    String // "session.terminate", "config.apply", "node.create"
  detail    String? // JSON context
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  node      Node?    @relation(fields: [nodeId], references: [id])

  @@index([userId])
  @@index([nodeId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Config — key-value settings store
// ---------------------------------------------------------------------------

model Setting {
  key   String @id
  value String
}

// ---------------------------------------------------------------------------
// Alerting — threshold rules + fired-event history
// ---------------------------------------------------------------------------

model AlertRule {
  id         String       @id @default(cuid())
  name       String
  nodeId     String? // null = applies to every node
  metric     String // node_offline | cpu_percent | mem_percent | disk_percent | session_count
  operator   String       @default("gt") // gt | lt
  threshold  Float        @default(0)
  enabled    Boolean      @default(true)
  webhookUrl String? // optional outbound webhook on breach
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  events     AlertEvent[]

  @@index([enabled])
}

model AlertEvent {
  id        String    @id @default(cuid())
  ruleId    String
  ruleName  String
  nodeId    String?
  nodeName  String?
  metric    String
  value     Float
  threshold Float
  message   String
  createdAt DateTime  @default(now())
  rule      AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([createdAt])
}
