# dawu-manager environment configuration
# Copy this file to .env and update values

# REQUIRED: Secret for JWT signing and API key encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-string

# Base URL of this dawu-manager instance
# Change if using a custom domain or port
NEXTAUTH_URL=http://localhost:3789

# Server port (default: 3789)
PORT=3789
